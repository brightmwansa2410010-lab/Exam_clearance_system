# Copy this file to .env and update the values
DATABASE_URL=postgresql://postgres:password@localhost:5432/exam_clearance
JWT_SECRET=change_this_secret
PORT=4000

# DB setup script credentials (if not using DATABASE_URL)
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_HOST=localhost
DB_PORT=5432

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:4000

# Upload directory (local). For production with multiple instances, use S3 via multer-s3.
UPLOAD_DIR=uploads
